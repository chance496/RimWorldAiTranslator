  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <AssemblyName>RimWorldAiTranslator</AssemblyName>
    <RootNamespace>RimWorldAiTranslator.App</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="..\..\rimworld-def-field-rules.txt" Link="rimworld-def-field-rules.txt" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" ExcludeFromSingleFile="true" />
    <Content Include="..\..\glossary.generated.ko.json" Link="glossary.generated.ko.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" ExcludeFromSingleFile="true" />
  </ItemGroup>

