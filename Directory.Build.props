<Project>
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>true</Deterministic>
    <AnalysisMode>Recommended</AnalysisMode>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <Version>1.0.1-rc.1</Version>
    <FileVersion>1.0.1.0</FileVersion>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <Company>chance496</Company>
    <Product>RimWorld AI Translator</Product>
    <Description>Safe local translation and review workflow for RimWorld mods.</Description>
    <Copyright>Copyright (c) 2026 wjdck</Copyright>
  </PropertyGroup>
</Project>
